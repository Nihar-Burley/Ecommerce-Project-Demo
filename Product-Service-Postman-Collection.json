{
  "info": {
    "name": "Product Service APIs (Production)",
    "_postman_id": "prod-12345",
    "description": "Product Service including CRUD + Stock APIs",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [

    {
      "name": "Get All Products",
      "request": {
        "method": "GET",
        "url": {
          "raw": "http://localhost:8081/api/v1/products",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8081",
          "path": ["api", "v1", "products"]
        }
      }
    },

    {
      "name": "Get Product By ID",
      "request": {
        "method": "GET",
        "url": {
          "raw": "http://localhost:8081/api/v1/products/1",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8081",
          "path": ["api", "v1", "products", "1"]
        }
      }
    },

    {
      "name": "Create Product",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"MacBook Pro\",\n  \"description\": \"Apple laptop\",\n  \"price\": 150000,\n  \"stock\": 5\n}"
        },
        "url": {
          "raw": "http://localhost:8081/api/v1/products",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8081",
          "path": ["api", "v1", "products"]
        }
      }
    },

    {
      "name": "Update Product",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Updated Product\",\n  \"description\": \"Updated Desc\",\n  \"price\": 120000,\n  \"stock\": 3\n}"
        },
        "url": {
          "raw": "http://localhost:8081/api/v1/products/1",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8081",
          "path": ["api", "v1", "products", "1"]
        }
      }
    },

    {
      "name": "Delete Product",
      "request": {
        "method": "DELETE",
        "url": {
          "raw": "http://localhost:8081/api/v1/products/1",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8081",
          "path": ["api", "v1", "products", "1"]
        }
      }
    },

    {
      "name": "Reduce Stock",
      "request": {
        "method": "PUT",
        "url": {
          "raw": "http://localhost:8081/api/v1/products/1/reduce/2",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8081",
          "path": ["api", "v1", "products", "1", "reduce", "2"]
        }
      }
    },

    {
      "name": "Increase Stock",
      "request": {
        "method": "PUT",
        "url": {
          "raw": "http://localhost:8081/api/v1/products/1/increase/3",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8081",
          "path": ["api", "v1", "products", "1", "increase", "3"]
        }
      }
    }

  ]
}